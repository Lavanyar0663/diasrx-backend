<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_card_rounded_white"
    android:padding="16dp"
    android:elevation="0dp">

    <!-- Avatar -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivAvatar"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@drawable/ic_person"
        app:shapeAppearanceOverlay="@style/CircleAppearance"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Details -->
    <TextView
        android:id="@+id/tvName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Dr. Sarah Jenkins"
        android:textColor="@color/colorSecondary"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/ivAvatar"
        app:layout_constraintTop_toTopOf="@+id/ivAvatar" />

    <!-- Role Badge (pill shape) -->
    <TextView
        android:id="@+id/tvRoleBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_badge_blue"
        android:paddingHorizontal="10dp"
        android:paddingVertical="3dp"
        android:text="DOCTOR"
        android:textColor="#0052CC"
        android:textSize="11sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@+id/tvName"
        app:layout_constraintTop_toBottomOf="@+id/tvName" />

    <TextView
        android:id="@+id/tvTime"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:text="• 2m ago"
        android:textColor="@color/colorTextSecondary"
        android:textSize="13sp"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constrainedWidth="true"
        app:layout_constraintBottom_toBottomOf="@+id/tvRoleBadge"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toEndOf="@+id/tvRoleBadge"
        app:layout_constraintTop_toTopOf="@+id/tvRoleBadge" />



    <!-- Action Buttons Container (Tightly constrained) -->
    <LinearLayout
        android:id="@+id/llActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/tvRoleBadge"
        app:layout_constraintTop_toBottomOf="@+id/tvRoleBadge">

        <!-- Pending State -->
        <LinearLayout
            android:id="@+id/llPendingActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="visible">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReject"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="Reject"
                android:textColor="#D32F2F"
                android:textSize="12sp"
                app:cornerRadius="20dp"
                app:strokeColor="#D32F2F" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApprove"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:backgroundTint="#00897B"
                android:text="Approve"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:cornerRadius="20dp" />
        </LinearLayout>

        <!-- Approved/Rejected State (Inline) -->
        <LinearLayout
            android:id="@+id/llStatusActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewProfileItem"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="View Profile"
                android:textColor="#00897B"
                android:textSize="12sp"
                app:cornerRadius="20dp"
                app:strokeColor="#00897B" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewReasonItem"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="View Reason"
                android:textColor="#D32F2F"
                android:textSize="12sp"
                app:cornerRadius="20dp"
                app:strokeColor="#D32F2F" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/btnShowProfile"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/llRejectedActions"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
