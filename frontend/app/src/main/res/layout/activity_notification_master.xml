<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:padding="12dp"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#1E293B" />

    <TextView
        android:id="@+id/tvHeaderTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Notification Master"
        android:textColor="#1E293B"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btnBack"
        app:layout_constraintStart_toEndOf="@+id/btnBack"
        app:layout_constraintTop_toTopOf="@+id/btnBack" />

    <TextView
        android:id="@+id/tvHeaderSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ADMIN INTERFACE"
        android:textColor="@color/colorPrimary"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@+id/tvHeaderTitle"
        app:layout_constraintTop_toBottomOf="@+id/tvHeaderTitle" />

    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:text="Manage hospital-wide alert configurations and delivery channels."
        android:textColor="#64748B"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvHeaderSubtitle" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toTopOf="@+id/btnSave"
        app:layout_constraintTop_toBottomOf="@+id/tvDescription">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp">

            <!-- Section: Prescription Alerts -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="PRESCRIPTION ALERTS"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#F1F5F9"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <View
                        android:id="@+id/iconBg1"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_glow"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_medication"
                        app:layout_constraintBottom_toBottomOf="@+id/iconBg1"
                        app:layout_constraintEnd_toEndOf="@+id/iconBg1"
                        app:layout_constraintStart_toStartOf="@+id/iconBg1"
                        app:layout_constraintTop_toTopOf="@+id/iconBg1"
                        app:tint="@color/colorPrimary" />

                    <TextView
                        android:id="@+id/tvTitle1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Doctor to Pharmacist"
                        android:textColor="#1E293B"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@+id/switch1"
                        app:layout_constraintStart_toEndOf="@+id/iconBg1"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="New prescription routing alerts"
                        android:textColor="#64748B"
                        android:textSize="11sp"
                        app:layout_constraintEnd_toStartOf="@+id/switch1"
                        app:layout_constraintStart_toStartOf="@+id/tvTitle1"
                        app:layout_constraintTop_toBottomOf="@+id/tvTitle1" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section: Patient Reminders -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="PATIENT REMINDERS"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#F1F5F9"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <View
                            android:id="@+id/iconBg2"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_glow"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_messages"
                            app:layout_constraintBottom_toBottomOf="@+id/iconBg2"
                            app:layout_constraintEnd_toEndOf="@+id/iconBg2"
                            app:layout_constraintStart_toStartOf="@+id/iconBg2"
                            app:layout_constraintTop_toTopOf="@+id/iconBg2"
                            app:tint="@color/colorPrimary" />

                        <TextView
                            android:id="@+id/tvTitle2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="WhatsApp Notifications"
                            android:textColor="#1E293B"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toStartOf="@+id/switch2"
                            app:layout_constraintStart_toEndOf="@+id/iconBg2"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Appointment &amp; Follow-up texts"
                            android:textColor="#64748B"
                            android:textSize="11sp"
                            app:layout_constraintEnd_toStartOf="@+id/switch2"
                            app:layout_constraintStart_toStartOf="@+id/tvTitle2"
                            app:layout_constraintTop_toBottomOf="@+id/tvTitle2" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="#F1F5F9"
                        android:layout_marginStart="56dp" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <View
                            android:id="@+id/iconBg3"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_glow"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_email"
                            app:layout_constraintBottom_toBottomOf="@+id/iconBg3"
                            app:layout_constraintEnd_toEndOf="@+id/iconBg3"
                            app:layout_constraintStart_toStartOf="@+id/iconBg3"
                            app:layout_constraintTop_toTopOf="@+id/iconBg3"
                            app:tint="@color/colorPrimary" />

                        <TextView
                            android:id="@+id/tvTitle3"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="Email Campaigns"
                            android:textColor="#1E293B"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toStartOf="@+id/switch3"
                            app:layout_constraintStart_toEndOf="@+id/iconBg3"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Patient newsletters &amp; reports"
                            android:textColor="#64748B"
                            android:textSize="11sp"
                            app:layout_constraintEnd_toStartOf="@+id/switch3"
                            app:layout_constraintStart_toStartOf="@+id/tvTitle3"
                            app:layout_constraintTop_toBottomOf="@+id/tvTitle3" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section: System Alerts -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="SYSTEM ALERTS"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#F1F5F9"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <View
                            android:id="@+id/iconBg4"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_glow"
                            android:backgroundTint="#FFF1F2"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_security"
                            app:layout_constraintBottom_toBottomOf="@+id/iconBg4"
                            app:layout_constraintEnd_toEndOf="@+id/iconBg4"
                            app:layout_constraintStart_toStartOf="@+id/iconBg4"
                            app:layout_constraintTop_toTopOf="@+id/iconBg4"
                            app:tint="#F43F5E" />

                        <TextView
                            android:id="@+id/tvTitle4"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="Security &amp; Access"
                            android:textColor="#1E293B"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toStartOf="@+id/switch4"
                            app:layout_constraintStart_toEndOf="@+id/iconBg4"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Unusual login &amp; permission changes"
                            android:textColor="#64748B"
                            android:textSize="11sp"
                            app:layout_constraintEnd_toStartOf="@+id/switch4"
                            app:layout_constraintStart_toStartOf="@+id/tvTitle4"
                            app:layout_constraintTop_toBottomOf="@+id/tvTitle4" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="16dp"
                        android:background="#F1F5F9"
                        android:layout_marginStart="56dp" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <View
                            android:id="@+id/iconBg5"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_glow"
                            android:backgroundTint="#FFF1F2"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_storage"
                            app:layout_constraintBottom_toBottomOf="@+id/iconBg5"
                            app:layout_constraintEnd_toEndOf="@+id/iconBg5"
                            app:layout_constraintStart_toStartOf="@+id/iconBg5"
                            app:layout_constraintTop_toTopOf="@+id/iconBg5"
                            app:tint="#F43F5E" />

                        <TextView
                            android:id="@+id/tvTitle5"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="Database Latency"
                            android:textColor="#1E293B"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:layout_constraintEnd_toStartOf="@+id/switch5"
                            app:layout_constraintStart_toEndOf="@+id/iconBg5"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="Alerts for slow query performance"
                            android:textColor="#64748B"
                            android:textSize="11sp"
                            app:layout_constraintEnd_toStartOf="@+id/switch5"
                            app:layout_constraintStart_toStartOf="@+id/tvTitle5"
                            app:layout_constraintTop_toBottomOf="@+id/tvTitle5" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch5"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section: Administrative -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="ADMINISTRATIVE"
                android:textColor="#94A3B8"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#F1F5F9"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <View
                        android:id="@+id/iconBg6"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_glow"
                        android:backgroundTint="#F5F3FF"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_person"
                        app:layout_constraintBottom_toBottomOf="@+id/iconBg6"
                        app:layout_constraintEnd_toEndOf="@+id/iconBg6"
                        app:layout_constraintStart_toStartOf="@+id/iconBg6"
                        app:layout_constraintTop_toTopOf="@+id/iconBg6"
                        app:tint="#8B5CF6" />

                    <TextView
                        android:id="@+id/tvTitle6"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Staff Onboarding"
                        android:textColor="#1E293B"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@+id/switch6"
                        app:layout_constraintStart_toEndOf="@+id/iconBg6"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Alerts for new staff registrations"
                        android:textColor="#64748B"
                        android:textSize="11sp"
                        app:layout_constraintEnd_toStartOf="@+id/switch6"
                        app:layout_constraintStart_toStartOf="@+id/tvTitle6"
                        app:layout_constraintTop_toBottomOf="@+id/tvTitle6" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="24dp"
        android:text="Save Global Changes"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        android:letterSpacing="0"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
