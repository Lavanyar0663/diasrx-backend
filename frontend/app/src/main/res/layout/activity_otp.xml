<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    tools:context=".OtpActivity">

    <!-- Header -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:padding="8dp"
        android:src="@android:drawable/ic_menu_revert"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/colorSecondary" />

    <TextView
        android:id="@+id/tvHeaderTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DIAS RX"
        android:textColor="@color/colorSecondary"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@+id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/btnBack" />

    <!-- Icon Background -->
    <View
        android:id="@+id/iconBg"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="60dp"
        android:background="@drawable/bg_circle_cyan_light"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvHeaderTitle" />

    <ImageView
        android:id="@+id/ivVerifyIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@android:drawable/checkbox_on_background"
        app:layout_constraintBottom_toBottomOf="@+id/iconBg"
        app:layout_constraintEnd_toEndOf="@+id/iconBg"
        app:layout_constraintStart_toStartOf="@+id/iconBg"
        app:layout_constraintTop_toTopOf="@+id/iconBg"
        app:tint="@color/colorPrimary" />

    <!-- Text -->
    <TextView
        android:id="@+id/tvVerifyTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="40dp"
        android:text="Verification Code"
        android:textColor="@color/colorSecondary"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/iconBg" />

    <TextView
        android:id="@+id/tvVerifySubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="40dp"
        android:text="Enter the 6-digit code sent to your email address."
        android:textColor="@color/colorTextSecondary"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/tvVerifyTitle"
        app:layout_constraintTop_toBottomOf="@+id/tvVerifyTitle" />

    <!-- OTP Input Boxes -->
    <LinearLayout
        android:id="@+id/llOtpContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="40dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/tvVerifySubtitle">

        <EditText
            android:id="@+id/etOtp1"
            style="@style/OtpEditTextStyle"
            android:nextFocusForward="@+id/etOtp2" />

        <EditText
            android:id="@+id/etOtp2"
            style="@style/OtpEditTextStyle"
            android:layout_marginStart="8dp"
            android:nextFocusForward="@+id/etOtp3" />

        <EditText
            android:id="@+id/etOtp3"
            style="@style/OtpEditTextStyle"
            android:layout_marginStart="8dp"
            android:nextFocusForward="@+id/etOtp4" />

        <EditText
            android:id="@+id/etOtp4"
            style="@style/OtpEditTextStyle"
            android:layout_marginStart="8dp"
            android:nextFocusForward="@+id/etOtp5" />

        <EditText
            android:id="@+id/etOtp5"
            style="@style/OtpEditTextStyle"
            android:layout_marginStart="8dp"
            android:nextFocusForward="@+id/etOtp6" />

        <EditText
            android:id="@+id/etOtp6"
            style="@style/OtpEditTextStyle"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvResendText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Resend code in 00:45"
        android:textColor="@color/colorTextSecondary"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/llOtpContainer" />

    <TextView
        android:id="@+id/tvResendCode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="RESEND CODE"
        android:textColor="@color/colorTextSecondary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:alpha="0.5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvResendText" />

    <!-- Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVerify"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="40dp"
        android:backgroundTint="@color/colorPrimary"
        android:text="Verify &amp; Proceed"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="32dp"
        app:layout_constraintTop_toBottomOf="@+id/tvResendCode" />

    <!-- Footer -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="By continuing, you agree to DIAS Rx\nTerms of Service and Privacy Policy"
        android:textColor="@color/colorTextSecondary"
        android:textSize="12sp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
