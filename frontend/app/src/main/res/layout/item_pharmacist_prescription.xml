<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card_rounded_white"
    android:elevation="0dp"
    app:strokeColor="#EAEAEA"
    app:strokeWidth="1dp">

    <!-- Left Border Indicator -->
    <View
        android:id="@+id/vStatusIndicator"
        android:layout_width="4dp"
        android:layout_height="0dp"
        android:background="#FF9800"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Avatar -->
        <ImageView
            android:id="@+id/ivPatientAvatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_grey"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/tvAvatarInitials"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:gravity="center"
            android:text="JD"
            android:textColor="#546E7A"
            android:textSize="14sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/ivPatientAvatar"
            app:layout_constraintEnd_toEndOf="@+id/ivPatientAvatar"
            app:layout_constraintStart_toStartOf="@+id/ivPatientAvatar"
            app:layout_constraintTop_toTopOf="@+id/ivPatientAvatar" />

        <!-- Details -->
        <TextView
            android:id="@+id/tvPatientName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:text="John Doe"
            android:textColor="@color/colorSecondary"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/tvStatusBadge"
            app:layout_constraintStart_toEndOf="@+id/ivPatientAvatar"
            app:layout_constraintTop_toTopOf="@+id/ivPatientAvatar" />

        <!-- Doctor Info -->
        <ImageView
            android:id="@+id/ivDoctorIcon"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginTop="4dp"
            android:src="@android:drawable/ic_menu_myplaces"
            app:tint="@color/colorOutline"
            app:layout_constraintStart_toStartOf="@+id/tvPatientName"
            app:layout_constraintTop_toBottomOf="@+id/tvPatientName" />

        <TextView
            android:id="@+id/tvDoctorName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="Dr. Sarah Smith"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@+id/ivDoctorIcon"
            app:layout_constraintStart_toEndOf="@+id/ivDoctorIcon"
            app:layout_constraintTop_toTopOf="@+id/ivDoctorIcon" />

        <!-- Status Badge -->
        <TextView
            android:id="@+id/tvStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_light_orange"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="PENDING"
            android:textColor="#E65100"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tvPatientName" />

        <!-- Time -->
        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="10:42 AM"
            android:textColor="@color/colorOutline"
            android:textSize="11sp"
            app:layout_constraintEnd_toEndOf="@+id/tvStatusBadge"
            app:layout_constraintTop_toBottomOf="@+id/tvStatusBadge" />

        <!-- Dispense Action Button -->
        <ImageView
            android:id="@+id/ivChevron"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_send"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/colorPrimary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
